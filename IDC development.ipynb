    "import os\n",
    "os.environ[\"AZURE_CLIENTSID\"] = \"YOUR_CLIENTSID",
    "os.environ[\"AZURE_TENANT_ID\"] = \"YOUR_TENANT_ID",
    "os.environ[\"AZURE_CLIENT_SECRET\"] = \"YOUR_CLIENT_SECRET""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "10313972-400f-48f8-ad5f-f45652a8db1f",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Azure authentication successful\n"
     ]
    }
   ],
   "source": [
    "from azure.identity import ClientSecretCredential\n",
    "\n",
    "credential = ClientSecretCredential(\n",
    "    tenant_id=os.environ[\"AZURE_TENANT_ID\"],\n",
    "    client_id=os.environ[\"AZURE_CLIENTSID\"],\n",
    "    client_secret=os.environ[\"AZURE_CLIENT_SECRET\"]\n",
    ")\n",
    "\n",
    "print(\"Azure authentication successful\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "e3596ebe-2947-4c7f-91b5-f795ffbd2ac5",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "eyJ0eXAiOiJKV1QiLCJub25jZSI6IjBUZk4wNGQ1X0g3UFVxcnlGbE1ybk9PT3lkaWgyd1hrWkhob2x4YUlIN3ciLCJhbGciOiJS\n"
     ]
    }
   ],
   "source": [
    "token = credential.get_token(\"https://graph.microsoft.com/.default\")\n",
    "\n",
    "print(token.token[:100])"
   ]
  },
